---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} — Jerry Ho</title>
    <script is:inline>
  const theme = (() => {
    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
      return localStorage.getItem('theme');
    }
    if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
      return 'dark';
    }
    return 'light';
  })();

  document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>

  </head>
  <body class="max-w-2xl mx-auto px-6 py-12 font-sans bg-white text-black dark:bg-zinc-900 dark:text-white">
    <nav class="flex gap-6 mb-16 text-sm">
      <a href="/" class="hover:underline">Home</a>
      <a href="/about" class="hover:underline">About</a>
      <a href="/now" class="hover:underline">Now</a>
      <a href="/reviews" class="hover:underline">Reviews</a>
      <a href="/writing" class="hover:underline">Writing</a>
      <ThemeToggle /> 
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>
